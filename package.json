{
  "name": "neux",
  "version": "0.15.2",
  "description": "A lightweight frontend library for building dynamic user interfaces using declarative element definitions and reactive signals to modify them.",
  "author": "Anton Skshidlevsky <meefik@gmail.com>",
  "homepage": "https://meefik.dev/neux/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/meefik/neux.git"
  },
  "keywords": [
    "declarative",
    "frontend",
    "javascript",
    "library",
    "reactive",
    "ui"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/neux.esm.js",
  "module": "dist/neux.esm.js",
  "unpkg": "dist/neux.umd.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/neux.esm.js",
      "require": "./dist/neux.umd.js",
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "node --test 'tests/**/*.test.js'"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "jsdom": "^29.1.1",
    "rollup": "^4.62.2"
  }
}
